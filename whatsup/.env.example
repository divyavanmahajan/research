# Server
HOST=127.0.0.1
PORT=3000
DATABASE_PATH=./whatsup.db

# JWT signing secret (256-bit random hex — generate with: openssl rand -hex 32)
JWT_SECRET=replace_with_64_hex_chars

# TOTP secret encryption key (256-bit random hex — generate with: openssl rand -hex 32)
TOTP_ENCRYPTION_KEY=replace_with_64_hex_chars

# CORS allowed origin for the web client
CORS_ORIGIN=http://localhost:5173

# Upload directory
UPLOAD_DIR=./uploads

# Log level: trace, debug, info, warn, error
RUST_LOG=info
